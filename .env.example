# Provider keys. Use FINNHUB_API_KEY for the 5-symbol manual scan mode.
# FMP_API_KEY is still supported for the original FMP scan mode.
FMP_API_KEY=your_financial_modeling_prep_key_here
FINNHUB_API_KEY=your_finnhub_key_here

# Optional. Adds Alpha Vantage News & Sentiment as an external sentiment overlay.
# Alpha Vantage free usage is limited, so leave this blank if you want to conserve calls.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Use finnhub for the lower-call 5-symbol research workflow.
# Other options: auto or fmp.
DATA_PROVIDER=finnhub

# Choose the exact symbols the daily workflow scans.
# For Finnhub free mode, keep this to 5 symbols.
# For FMP/Alpha mode, keep this to 3 symbols unless you have a larger plan.
TRADE_TICKERS=SOFI,PLTR,HOOD,RIVN,F
MAX_SCAN_TICKERS=5

# Optional. Set to true as a GitHub Actions variable if you want the workflow to rebuild data/robinhood-universe.json.
BUILD_ROBINHOOD_UNIVERSE=false

# Optional local testing only. In GitHub, store this as a Secret named NETLIFY_BUILD_HOOK_URL.
NETLIFY_BUILD_HOOK_URL=
