# Required for real quote, volume, profile, historical price, and stock news data.
FMP_API_KEY=your_financial_modeling_prep_key_here

# Optional. Adds Alpha Vantage News & Sentiment as an external sentiment overlay.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Optional. Comma-separated research universe, or use ALL to scan from data/robinhood-universe.json.
# A small list can cause the same stock to keep winning.
TRADE_TICKERS=ALL

# Optional but recommended with TRADE_TICKERS=ALL. This prevents free/low-tier APIs from being exhausted.
# Increase gradually after confirming your provider limits.
MAX_SCAN_TICKERS=75

# Optional. Set to true as a GitHub Actions variable if you want the workflow to rebuild data/robinhood-universe.json.
BUILD_ROBINHOOD_UNIVERSE=false

# Optional. Use this if you wire the Python workflow to call a Netlify build hook after writing data/latest-picks.json.
NETLIFY_BUILD_HOOK_URL=
