{
  "name": "tradesignal-daily",
  "version": "1.0.0",
  "private": true,
  "description": "TradeSignal Daily - a personal Next.js 15 stock-movement research dashboard with real daily API data, factor scoring, and risk disclaimers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "update:picks": "python3 scripts/update_picks.py",
    "analyze:picks": "python3 scripts/update_picks.py",
    "update:universe": "python3 scripts/build_robinhood_universe.py",
    "update:all": "python3 scripts/build_robinhood_universe.py && python3 scripts/update_picks.py"
  },
  "dependencies": {
    "@netlify/functions": "^2.8.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.11",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "@tailwindcss/typography": "^0.5.15"
  }
}
